//Return button string name
#macro GMGUI_MENU_RETURN "BACK"

//GUI mouse index
#macro GMGUI_MENU_MOUSE_INDEX 0

//Font colour
#macro GMGUI_MENU_COLOUR #101010

//Font colour hover
#macro GMGUI_MENU_COLOUR_HOVER c_black

//Font scale hover
#macro GMGUI_MENU_SCALE_HOVER 1.1

//Font scale hover speed
#macro GMGUI_MENU_SCALE_HOVER_SPEED 0.01

//Slider background colour
#macro GMGUI_MENU_SLIDER_BACKGROUND_COLOUR c_ltgray

//Slider frame colour
#macro GMGUI_MENU_SLIDER_FRAME_COLOUR c_black

//Slider colour
#macro GMGUI_MENU_SLIDER_COLOUR c_gray



